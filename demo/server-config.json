[
  {
    "port": 8080,
    "folders": "demo/client-a",
    "proxy": {
      "/api": "http://localhost:4001"
    },
    "headers": {
      "X-Powered-By": "express-reverse-proxy",
      "X-Client": "A"
    },
    "unhandled": {
      "html": { "status": 307, "headers": { "Location": "/" } },
      "json": { "status": 404, "send": { "error": "Not Found" } }
    },
    "healthCheck": true,
    "responseTime": true,
    "cors": true,
    "helmet": true,
    "redirects": {
      "/old-page": "/",
      "/legacy": { "to": "/", "status": 302 }
    },
    "compression": true
  },
  {
    "port": 8081,
    "folders": "demo/client-b",
    "proxy": {
      "/api": "http://localhost:4002"
    },
    "headers": {
      "X-Powered-By": "express-reverse-proxy",
      "X-Client": "B"
    },
    "unhandled": {
      "html": { "status": 307, "headers": { "Location": "/" } },
      "json": { "status": 404, "send": { "error": "Not Found" } }
    }
  },
  {
    "port": 8082,
    "folders": "demo/client-a",
    "healthCheck": true,
    "basicAuth": { "users": { "admin": "secret" } }
  },
  {
    "port": 8083,
    "folders": "demo/client-a",
    "healthCheck": true,
    "rateLimit": { "windowMs": 10000, "limit": 3 }
  },
  {
    "port": 8084,
    "proxy": [{ "/api": "http://localhost:4001" }, { "/store": "http://localhost:4002" }]
  },
  {
    "port": 8085,
    "proxy": [["http://localhost:4001", "http://localhost:4002"]]
  },
  {
    "port": 8086,
    "upload": {
      "path": "/upload",
      "dir": "./demo/uploads",
      "maxFileSize": 1024,
      "maxFiles": 2,
      "allowedTypes": ["text/plain"]
    }
  }
]
